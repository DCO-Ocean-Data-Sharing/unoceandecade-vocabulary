:QOy8Js a skos:Concept;
  skos:prefLabel "UN Ocean Decade Challenge"@en;
  skos:definition "The Ocean Decade Challenges represent the highest level of the Ocean Decade action framework. They articulate the most immediate priorities for implementation and aim to unite partners in collective action, thus ensuring that the whole of the initiative is greater than the sum of its parts. In doing so, the Challenges shape the overall contribution of the Decade to the 2030 Agenda for Sustainable Development and other policy frameworks. The Challenges were distilled from discussions with stakeholders throughout the preparation phase of the Ocean Decade (2018-2020), including regional consultation workshops. They may evolve and change as issues are resolved over the course of the Decade; and new Challenges may be added as issues emerge. They formed the foundation and framework of the Vision 2030 process conducted in 2023-2024 and related outcomes report."@en;
  skos:narrower :ok1YhP,
         :ijOvYT,
         :zSO9Li,
         :yWqKgv,
         :q8155u,
         :sfpAXw,
         :oAbaEY,
         :bCYJmi,
         :mVDokG,
         :Xd6PGU;
  skos:topConceptOf : ;
  dct:created "2026-07-22"^^xsd:date;
  dct:modified "2026-07-23"^^xsd:date .

:LC251f a skos:Concept;
  skos:prefLabel "UN Ocean Decade Outcome"@en;
  skos:narrower :V9sJQA,
         :RMaPyJ,
         :PUJx4T,
         :m6RMnm,
         :AIJZ3U,
         :yPHGUL,
