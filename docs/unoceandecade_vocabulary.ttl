  ], [
      a sdo:DigitalDocument;
      sdo:name "Understanding and beating marine pollution under Ocean Decade Vision 2030 Challenge 1"@en;
      sdo:url <https://doi.org/10.1093/icesjms/fsaf009>;
      sdo:datePublished "2025"^^xsd:gYear
  ] .

:ijOvYT a skos:Concept;
  skos:prefLabel "Protect and restore ecosystems and biodiversity"@en;
  skos:notation "Challenge 2";
  skos:definition "Understand the effects of multiple stressors on ocean ecosystems, and develop solutions to monitor, protect, manage and restore ecosystems and their biodiversity under changing environmental, social and climate conditions."@en;
  skos:broader :QOy8Js;
  skos:inScheme :;
  dct:source <https://oceandecade.org/challenges/>;
  dct:created "2026-07-22"^^xsd:date;
  dct:modified "2026-07-23"^^xsd:date;
