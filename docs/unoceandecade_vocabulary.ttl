<http://purl.org/oceandecade/voc#> a skos:ConceptScheme;
  dct:title "UN Decade of Ocean Sciences 2021-2030: Challenges, Outcomes and Solution Areas"@en;
  dct:creator [
      a dct:Agent, sdo:Person;
