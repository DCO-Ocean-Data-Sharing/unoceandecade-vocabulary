:saRGpW a skos:Concept;
    skos:prefLabel "UN Ocean Decade Solution Area"@en;
    skos:definition "Ocean Decade Solutions are the translation of ocean knowledge, partnerships, innovation, and capacity generated through the Ocean Decade into coordinated, collective action that supports policy, planning, investment, and decision-making. Each Solution brings together multiple pathways, recognizing that lasting impact requires alignment across sectors and levels of implementation. The Ocean Decade Solutions are designed to support informed decision-making and policy development at global, regional, national, and local levels through tangible and actionable measures. Their primary purpose is to help policymakers, governments, ocean managers, practitioners, investors, and other stakeholders accelerate informed and inclusive decisions for ocean sustainability."@en;
    skos:topConceptOf :;
    skos:narrower :ghguns,
                  :KT6YV8;
    dct:source <https://oceandecade.org/news/accelerating-ocean-solutions-to-2030-and-beyond-from-knowledge-to-action-through-the-ocean-decade/>;
  dct:created "2026-07-22"^^xsd:date;
  dct:modified "2026-07-23"^^xsd:date .  
  
:ok1YhP a skos:Concept;
  skos:prefLabel "Understand and beat marine pollution"@en;
  skos:notation "Challenge 1";
  skos:definition "Understand and map land and sea-based sources of pollutants and contaminants and their potential impacts on human health and ocean ecosystems and develop solutions to remove or mitigate them."@en;
  skos:broader :QOy8Js;
  skos:inScheme :;
  dct:source <https://oceandecade.org/challenges/>;
