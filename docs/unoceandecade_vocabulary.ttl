  skos:prefLabel "Sustainably nourish the global population"@en;
  skos:notation "Challenge 3";
  skos:definition "Generate knowledge, support innovation and develop solutions to optimize the role of the ocean in sustainably nourishing the world’s population under changing environmental, social and climate conditions."@en;
  skos:broader :QOy8Js;
  skos:inScheme :;
  dct:source <https://oceandecade.org/challenges/>;
